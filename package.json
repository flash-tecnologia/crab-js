{
  "name": "kafka-crab-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter kafka-crab-js build",
    "build:otel": "pnpm --filter kafka-crab-js-otel build",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter kafka-crab-js test",
    "typecheck": "pnpm -r typecheck",
    "fmt": "dprint fmt",
    "lint": "oxlint .",
    "trace:batch-example": "pnpm tsx example/otel-batch-trace.ts"
  },
  "devDependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/context-async-hooks": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-grpc": "catalog:",
    "@opentelemetry/exporter-trace-otlp-grpc": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@types/node": "25.2.3",
    "dprint": "^0.51.1",
    "esbuild": "^0.27.3",
    "kafka-crab-js": "workspace:*",
    "kafka-crab-js-otel": "workspace:*",
    "nanoid": "^5.1.6",
    "oxlint": "^1.48.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
