{
  "name": "kafka-crab-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter kafka-crab-js build",
    "build:otel": "pnpm --filter kafka-crab-js-otel build",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter kafka-crab-js test",
    "typecheck": "pnpm -r typecheck",
    "fmt": "dprint fmt",
    "lint": "oxlint .",
    "trace:batch-example": "pnpm tsx example/otel-batch-trace.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.2.0",
    "@opentelemetry/core": "^2.2.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/sdk-metrics": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^1.26.0",
    "@opentelemetry/sdk-trace-node": "^1.26.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/node": "25.0.2",
    "dprint": "^0.50.2",
    "esbuild": "^0.27.1",
    "kafka-crab-js": "workspace:*",
    "kafka-crab-js-otel": "workspace:*",
    "nanoid": "^5.1.6",
    "oxlint": "^1.33.0",
    "rimraf": "^6.1.2",
    "tsx": "^4.19.1",
    "typescript": "^5.9.3"
  }
}
