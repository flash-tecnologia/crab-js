{
  "name": "kafka-crab-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter kafka-crab-js build",
    "build:otel": "pnpm --filter kafka-crab-js-otel build",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter kafka-crab-js test",
    "typecheck": "pnpm -r typecheck",
    "fmt": "dprint fmt",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "dprint": "^0.50.2",
    "oxlint": "^1.33.0"
  }
}
