{
  "name": "kafka-crab-js",
  "version": "3.1.0",
  "keywords": [
    "N-API",
    "consumer",
    "diagnostics_channel",
    "kafka",
    "librdkafka",
    "napi",
    "napi-rs",
    "node-addon",
    "node-addon-api",
    "producer",
    "rust",
    "streaming"
  ],
  "homepage": "https://github.com/flash-tecnologia/kafka-crab-js",
  "license": "MIT",
  "author": "inaiat@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/flash-tecnologia/kafka-crab-js.git"
  },
  "files": [
    "dist",
    "js-binding.js",
    "js-binding.d.ts",
    "js-binding.cjs"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "check": "vp check --no-error-on-unmatched-pattern js-src tests/unit vite.config.ts tsconfig.json package.json README.md",
    "artifacts": "napi artifacts",
    "fmt": "vp fmt js-src tests/unit vite.config.ts tsconfig.json package.json README.md",
    "fmt:check": "vp fmt --check js-src tests/unit vite.config.ts tsconfig.json package.json README.md",
    "lint": "vp lint js-src tests/unit vite.config.ts",
    "lint:fix": "vp lint --fix js-src tests/unit vite.config.ts",
    "prebuild": "napi build --platform",
    "build": "vp pack",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vp test",
    "test:integration": "node --test tests/integration/*.test.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  },
  "napi": {
    "binaryName": "kafka-crab-js",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
