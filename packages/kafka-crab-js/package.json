{
  "name": "kafka-crab-js",
  "version": "4.1.1",
  "keywords": [
    "N-API",
    "consumer",
    "diagnostics_channel",
    "kafka",
    "librdkafka",
    "napi",
    "napi-rs",
    "node-addon",
    "node-addon-api",
    "producer",
    "rust",
    "streaming"
  ],
  "homepage": "https://github.com/flash-tecnologia/crab-js",
  "license": "MIT",
  "author": "inaiat@gmail.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flash-tecnologia/crab-js.git",
    "directory": "packages/kafka-crab-js"
  },
  "files": [
    "assets",
    "dist",
    "js-binding.js",
    "js-binding.d.ts",
    "js-binding.cjs"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "check": "vp check",
    "artifacts": "napi artifacts",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "build": "node build.mjs",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "vp test run js-tests/unit",
    "test:integration": "node --test js-tests/integration/*.test.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@napi-rs/cli": "catalog:"
  },
  "napi": {
    "binaryName": "kafka-crab-js",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": ">=22"
  }
}
