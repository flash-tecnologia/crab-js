{
  "name": "kafka-crab-js-otel",
  "version": "1.1.0",
  "description": "OpenTelemetry instrumentation for kafka-crab-js",
  "keywords": [
    "instrumentation",
    "kafka",
    "metrics",
    "observability",
    "opentelemetry",
    "otel",
    "tracing"
  ],
  "homepage": "https://github.com/flash-tecnologia/kafka-crab-js",
  "license": "MIT",
  "author": "inaiat@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/flash-tecnologia/kafka-crab-js.git",
    "directory": "packages/kafka-crab-js-otel"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "check": "pnpm run fmt:check && pnpm run lint",
    "fmt": "node ../../scripts/run-vite-ox-tool.mjs fmt src tests vite.config.ts tsconfig.json package.json README.md",
    "fmt:check": "node ../../scripts/run-vite-ox-tool.mjs fmt --check src tests vite.config.ts tsconfig.json package.json README.md",
    "lint": "node ../../scripts/run-vite-ox-tool.mjs lint src tests vite.config.ts",
    "lint:fix": "node ../../scripts/run-vite-ox-tool.mjs lint --fix src tests vite.config.ts",
    "typecheck": "tsc -p . --noEmit",
    "build": "vp pack",
    "test": "vp test",
    "test:integration": "node --test tests/integration/*.test.*"
  },
  "devDependencies": {
    "kafka-crab-js": "workspace:*",
    "vite-plus": "0.1.19"
  },
  "peerDependencies": {
    "@opentelemetry/api": ">=1.9",
    "kafka-crab-js": ">=3"
  },
  "engines": {
    "node": ">=22"
  }
}
